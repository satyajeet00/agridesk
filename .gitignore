# =========================================================================
# AgriDesk monorepo .gitignore
# Repo root: this folder (Agridesk/) — pushed to github.com/satyajeet00/agridesk
# Tracked: agridesk-api/, agridesk-web/, docs/, .github/, README.md, LICENSE
# =========================================================================

# --- OS / IDE -------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.iml
*.swp
*~

# --- Environment / secrets ------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.keystore
*.jks
.razorpay-secrets
secrets.yml
application-prod.yml
application-local.yml

# --- Java / Maven (agridesk-api) -----------------------------------------
**/target/
**/*.class
**/*.jar
**/*.war
**/*.ear
**/.mvn/wrapper/maven-wrapper.jar
**/dependency-reduced-pom.xml
**/hs_err_pid*.log
**/replay_pid*.log

# JaCoCo / surefire artifacts (committing the report folder would be huge)
**/site/jacoco/
**/surefire-reports/

# Local H2 file DB (created by application.yml's jdbc:h2:file:./data/agridesk)
**/data/
*.h2.db
*.mv.db
*.trace.db

# --- Node / Next.js (agridesk-web) ---------------------------------------
**/node_modules/
**/.next/
**/out/
**/dist/
**/build/
**/.turbo/
**/coverage/
**/.swc/
**/*.tsbuildinfo
**/next-env.d.ts

# npm / yarn / pnpm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp.*

# --- Playwright (agridesk-web/tests-e2e) ---------------------------------
**/playwright-report/
**/playwright/.cache/
**/test-results/
**/blob-report/

# Stray Playwright logs we wrote during local runs
playwright-run-*.log

# --- Boot logs (from local mvn spring-boot:run smoke-tests) --------------
**/boot.log
**/boot.err.log
mvn-*.log

# --- Generic logs ---------------------------------------------------------
*.log

# --- Lock files: keep them -----------------------------------------------
# Do NOT ignore package-lock.json, yarn.lock, pnpm-lock.yaml — those are tracked.
